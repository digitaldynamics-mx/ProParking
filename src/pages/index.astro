---
import Layout from '../layouts/Layout.astro';
import FobIsotipo from '../components/FobIsotipo.astro';
import MobileMenu from '../components/MobileMenu.tsx';
import HowItWorks from '../components/HowItWorks.tsx';
import Stats from '../components/Stats.tsx';
import DemoForm from '../components/DemoForm.tsx';
import FAQ from '../components/FAQ.tsx';
const b = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout
  title="ProParking · Digital Partner — Valet profesional para restaurantes, hoteles y plazas"
  description="Sistema de valet parking trazable para negocios en México. QR por llave, control de efectivo, fotos de daños y administración web en tiempo real."
>

  <!-- ═══════════════════════════════════════════
       NAVBAR
  ═══════════════════════════════════════════ -->
  <header class="sticky top-0 z-40 bg-[#F1EFE8]/96 backdrop-blur-sm border-b border-[#2C2C2A]/8">
    <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href={`${b}/`} class="flex items-center gap-2.5 flex-shrink-0">
        <img
          src={`${b}/brand/Logo.png`}
          alt="ProParking Digital Partner"
          class="h-14 w-auto"
          style="mix-blend-mode: multiply;"
        />
      </a>
      <div class="hidden md:flex items-center gap-8">
        <a href="#como-funciona"   class="text-[#2C2C2A]/55 hover:text-[#2C2C2A] text-sm transition">Cómo funciona</a>
        <a href="#para-el-dueno"   class="text-[#2C2C2A]/55 hover:text-[#2C2C2A] text-sm transition">Panel admin</a>
        <a href="#resultados"      class="text-[#2C2C2A]/55 hover:text-[#2C2C2A] text-sm transition">Resultados</a>
        <a href="#precios"         class="text-[#2C2C2A]/55 hover:text-[#2C2C2A] text-sm transition">Precios</a>
        <a href="#demo"            class="bg-[#D85A30] text-white px-5 py-2.5 text-sm font-semibold hover:bg-[#c04f28] transition rounded-sm">
          Solicitar demo
        </a>
      </div>
      <MobileMenu client:load />
    </nav>
  </header>


  <!-- ═══════════════════════════════════════════
       1. HERO
  ═══════════════════════════════════════════ -->
  <section class="bg-[#2C2C2A] overflow-hidden">
    <div class="max-w-6xl mx-auto px-6 py-20 md:py-28 grid md:grid-cols-[1fr_auto] gap-12 md:gap-20 items-center">

      <!-- Copy -->
      <div class="animate-fade-up">
        <p class="font-mono text-[#888780] text-[11px] tracking-[.25em] uppercase mb-8">
          Valet parking · Hecho en México
        </p>

        <h1
          class="font-serif italic text-[#F1EFE8] leading-[1.08] mb-6"
          style="font-size: clamp(2.6rem, 5.2vw, 4rem);"
        >
          El valet de tu negocio,<br/>
          profesional desde<br/>
          el primer auto.
        </h1>

        <p class="text-[#888780] text-lg leading-relaxed max-w-md mb-10">
          ProParking convierte tu operación de valet en un servicio trazable, controlado y sin sorpresas — sin capacitar a tu equipo desde cero.
        </p>

        <div class="flex flex-wrap gap-4 mb-9">
          <a
            href="#demo"
            class="bg-[#D85A30] text-white px-7 py-3.5 font-semibold hover:bg-[#c04f28] transition rounded-sm text-sm tracking-wide"
          >
            Solicitar demo
          </a>
          <a
            href="#como-funciona"
            class="border border-[#888780]/35 text-[#888780] px-7 py-3.5 font-semibold hover:border-[#F1EFE8]/35 hover:text-[#F1EFE8] transition rounded-sm text-sm tracking-wide"
          >
            Ver cómo funciona
          </a>
        </div>

      </div>

      <!-- Hero animated mockup -->
      <div class="animate-fade-up delay-200 flex justify-center md:justify-end min-w-0">
        <div class="relative w-full md:w-[480px] h-[440px]">

          <!-- Ambient glow -->
          <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:260px;height:340px;background:radial-gradient(ellipse at center,rgba(29,158,117,.13) 0%,transparent 70%);pointer-events:none;"></div>

          <!-- Phone frame -->
          <div style="position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);width:248px;height:402px;background:#111110;border-radius:26px;border:1px solid rgba(255,255,255,.12);box-shadow:0 40px 80px rgba(0,0,0,.65),inset 0 1px 0 rgba(255,255,255,.06);overflow:hidden;display:flex;flex-direction:column;">

            <!-- App chrome bar -->
            <div style="background:#0e0e0d;padding:10px 14px 8px;display:flex;align-items:center;gap:6px;flex-shrink:0;">
              <div style="display:flex;gap:4px;">
                <div style="width:7px;height:7px;border-radius:50%;background:rgba(255,255,255,.15);"></div>
                <div style="width:7px;height:7px;border-radius:50%;background:rgba(255,255,255,.15);"></div>
                <div style="width:7px;height:7px;border-radius:50%;background:rgba(255,255,255,.15);"></div>
              </div>
              <div style="flex:1;text-align:center;">
                <span style="font-family:'JetBrains Mono',monospace;font-size:9px;color:#888780;letter-spacing:.12em;">ProParking</span>
              </div>
              <div style="display:flex;align-items:center;gap:3px;">
                <div class="fob-led" style="width:5px;height:5px;border-radius:50%;background:#1D9E75;"></div>
                <span style="font-family:'JetBrains Mono',monospace;font-size:8px;color:#1D9E75;">vivo</span>
              </div>
            </div>

            <!-- Screen -->
            <div style="flex:1;background:#F1EFE8;padding:12px 11px;display:flex;flex-direction:column;gap:9px;overflow:hidden;">

              <p style="font-family:'JetBrains Mono',monospace;font-size:8px;color:#888780;letter-spacing:.18em;text-transform:uppercase;">Ticket activo</p>

              <!-- Ticket card -->
              <div style="background:white;border-radius:12px;padding:11px;border:1px solid rgba(44,44,42,.08);flex:1;display:flex;flex-direction:column;gap:9px;">

                <!-- Header -->
                <div style="display:flex;justify-content:space-between;align-items:flex-start;">
                  <div>
                    <p style="font-family:'JetBrains Mono',monospace;font-size:20px;font-weight:500;color:#D85A30;line-height:1;">#4821</p>
                    <p style="font-family:'Plus Jakarta Sans',sans-serif;font-size:11px;color:#2C2C2A;font-weight:600;margin-top:2px;">Toyota Camry</p>
                    <p style="font-family:'JetBrains Mono',monospace;font-size:8px;color:#888780;margin-top:1px;">GZA-18-40 · Plata</p>
                  </div>
                  <div style="display:flex;align-items:center;gap:3px;background:#DCFCE7;padding:3px 8px;border-radius:20px;flex-shrink:0;">
                    <div class="fob-led" style="width:5px;height:5px;border-radius:50%;background:#1D9E75;"></div>
                    <span style="font-family:'JetBrains Mono',monospace;font-size:7.5px;color:#1D9E75;font-weight:500;">Activo</span>
                  </div>
                </div>

                <!-- QR code -->
                <div style="position:relative;background:#F8F7F4;border-radius:8px;padding:8px;display:flex;justify-content:center;align-items:center;overflow:hidden;">
                  <svg width="72" height="72" viewBox="0 0 72 72" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="2" y="2" width="20" height="20" rx="3" stroke="#2C2C2A" stroke-width="2.5"/>
                    <rect x="7" y="7" width="10" height="10" rx="1.5" fill="#2C2C2A"/>
                    <rect x="50" y="2" width="20" height="20" rx="3" stroke="#2C2C2A" stroke-width="2.5"/>
                    <rect x="55" y="7" width="10" height="10" rx="1.5" fill="#2C2C2A"/>
                    <rect x="2" y="50" width="20" height="20" rx="3" stroke="#2C2C2A" stroke-width="2.5"/>
                    <rect x="7" y="55" width="10" height="10" rx="1.5" fill="#2C2C2A"/>
                    <rect x="26" y="2" width="5" height="5" rx="1" fill="#2C2C2A"/>
                    <rect x="34" y="2" width="5" height="5" rx="1" fill="#2C2C2A"/>
                    <rect x="42" y="2" width="5" height="5" rx="1" fill="#2C2C2A"/>
                    <rect x="26" y="9" width="5" height="5" rx="1" fill="#D85A30"/>
                    <rect x="42" y="9" width="5" height="5" rx="1" fill="#2C2C2A"/>
                    <rect x="30" y="16" width="5" height="5" rx="1" fill="#2C2C2A"/>
                    <rect x="38" y="16" width="5" height="5" rx="1" fill="#2C2C2A"/>
                    <rect x="2" y="26" width="5" height="5" rx="1" fill="#2C2C2A"/>
                    <rect x="9" y="26" width="5" height="5" rx="1" fill="#1D9E75"/>
                    <rect x="16" y="26" width="5" height="5" rx="1" fill="#2C2C2A"/>
                    <rect x="26" y="26" width="5" height="5" rx="1" fill="#2C2C2A"/>
                    <rect x="34" y="26" width="5" height="5" rx="1" fill="#2C2C2A"/>
                    <rect x="42" y="26" width="5" height="5" rx="1" fill="#2C2C2A"/>
                    <rect x="50" y="26" width="5" height="5" rx="1" fill="#2C2C2A"/>
                    <rect x="58" y="26" width="5" height="5" rx="1" fill="#2C2C2A"/>
                    <rect x="65" y="26" width="5" height="5" rx="1" fill="#2C2C2A"/>
                    <rect x="2" y="34" width="5" height="5" rx="1" fill="#2C2C2A"/>
                    <rect x="16" y="34" width="5" height="5" rx="1" fill="#2C2C2A"/>
                    <rect x="26" y="34" width="5" height="5" rx="1" fill="#2C2C2A"/>
                    <rect x="42" y="34" width="5" height="5" rx="1" fill="#2C2C2A"/>
                    <rect x="50" y="34" width="5" height="5" rx="1" fill="#2C2C2A"/>
                    <rect x="65" y="34" width="5" height="5" rx="1" fill="#D85A30"/>
                    <rect x="34" y="50" width="5" height="5" rx="1" fill="#2C2C2A"/>
                    <rect x="42" y="50" width="5" height="5" rx="1" fill="#2C2C2A"/>
                    <rect x="50" y="50" width="5" height="5" rx="1" fill="#2C2C2A"/>
                    <rect x="58" y="50" width="5" height="5" rx="1" fill="#2C2C2A"/>
                    <rect x="65" y="50" width="5" height="5" rx="1" fill="#2C2C2A"/>
                    <rect x="26" y="58" width="5" height="5" rx="1" fill="#2C2C2A"/>
                    <rect x="34" y="58" width="5" height="5" rx="1" fill="#1D9E75"/>
                    <rect x="50" y="58" width="5" height="5" rx="1" fill="#2C2C2A"/>
                    <rect x="65" y="58" width="5" height="5" rx="1" fill="#2C2C2A"/>
                    <rect x="26" y="65" width="5" height="5" rx="1" fill="#2C2C2A"/>
                    <rect x="42" y="65" width="5" height="5" rx="1" fill="#2C2C2A"/>
                    <rect x="58" y="65" width="5" height="5" rx="1" fill="#2C2C2A"/>
                  </svg>
                  <!-- Scan beam -->
                  <div class="hero-scan" style="position:absolute;left:8px;right:8px;height:1.5px;background:linear-gradient(90deg,transparent,#D85A30 30%,#D85A30 70%,transparent);border-radius:1px;pointer-events:none;"></div>
                </div>

                <!-- Valetero + amount -->
                <div style="display:flex;justify-content:space-between;align-items:flex-end;">
                  <div>
                    <p style="font-family:'JetBrains Mono',monospace;font-size:7.5px;color:#888780;text-transform:uppercase;letter-spacing:.1em;">Valetero</p>
                    <p style="font-family:'Plus Jakarta Sans',sans-serif;font-size:10px;color:#2C2C2A;font-weight:600;margin-top:1px;">Pedro Ríos</p>
                  </div>
                  <div style="text-align:right;">
                    <p style="font-family:'JetBrains Mono',monospace;font-size:7.5px;color:#888780;text-transform:uppercase;letter-spacing:.1em;">Cobrado</p>
                    <p style="font-family:'JetBrains Mono',monospace;font-size:15px;color:#2C2C2A;font-weight:500;margin-top:1px;line-height:1;">$80 <span style="font-size:9px;color:#888780;">MXN</span></p>
                  </div>
                </div>

              </div>

              <!-- Action buttons -->
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;">
                <div style="background:#2C2C2A;border-radius:8px;padding:8px;text-align:center;">
                  <span style="font-family:'Plus Jakarta Sans',sans-serif;font-size:9px;color:white;font-weight:600;">Entregar auto</span>
                </div>
                <div style="background:white;border-radius:8px;padding:8px;text-align:center;border:1px solid rgba(44,44,42,.1);">
                  <span style="font-family:'Plus Jakarta Sans',sans-serif;font-size:9px;color:#2C2C2A;font-weight:600;">Ver fotos</span>
                </div>
              </div>

            </div>
          </div>

          <!-- Floating badge: ✓ Ticket cerrado (top-right) -->
          <div class="hero-float-a" style="position:absolute;top:22px;right:2px;z-index:10;">
            <div class="hero-badge-a" style="background:white;border-radius:10px;padding:7px 10px;box-shadow:0 8px 24px rgba(0,0,0,.22);border:1px solid rgba(29,158,117,.2);min-width:120px;">
              <div style="display:flex;align-items:center;gap:6px;">
                <div style="width:18px;height:18px;border-radius:50%;background:#DCFCE7;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                  <span style="font-size:9px;color:#1D9E75;font-weight:700;">✓</span>
                </div>
                <div>
                  <p style="font-family:'JetBrains Mono',monospace;font-size:8px;color:#1D9E75;font-weight:500;line-height:1;white-space:nowrap;">Ticket cerrado</p>
                  <p style="font-family:'JetBrains Mono',monospace;font-size:7px;color:#888780;margin-top:2px;white-space:nowrap;">hace 2 min · #4820</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Floating badge: $80 cobrado (bottom-left) -->
          <div class="hero-float-b" style="position:absolute;bottom:40px;left:2px;z-index:10;">
            <div class="hero-badge-b" style="background:white;border-radius:10px;padding:7px 10px;box-shadow:0 8px 24px rgba(0,0,0,.22);border:1px solid rgba(216,90,48,.18);min-width:110px;">
              <div style="display:flex;align-items:center;gap:6px;">
                <div style="width:18px;height:18px;border-radius:50%;background:#FEE2D5;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                  <span style="font-size:10px;color:#D85A30;font-weight:700;">$</span>
                </div>
                <div>
                  <p style="font-family:'JetBrains Mono',monospace;font-size:8px;color:#D85A30;font-weight:500;line-height:1;white-space:nowrap;">$80 cobrado</p>
                  <p style="font-family:'JetBrains Mono',monospace;font-size:7px;color:#888780;margin-top:2px;white-space:nowrap;">Efectivo · hoy</p>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>

    </div>
    <div class="h-px bg-gradient-to-r from-transparent via-[#888780]/15 to-transparent"></div>
  </section>


  <!-- ═══════════════════════════════════════════
       2. PROBLEMA
  ═══════════════════════════════════════════ -->
  <section class="bg-[#F1EFE8] py-24">
    <div class="max-w-6xl mx-auto px-6">

      <!-- Section marker -->
      <div class="flex items-center gap-3 mb-14">
        <FobIsotipo variant="marker" />
        <p class="font-mono text-[#888780] text-[11px] tracking-[.22em] uppercase">El problema</p>
      </div>

      <div class="space-y-0 divide-y divide-[#2C2C2A]/8">
        {[
          {
            stat: '$180,000',
            statSub: 'pesos al año',
            text: 'Cada año pierdes ese promedio en faltantes de caja que nadie puede explicar.',
          },
          {
            stat: '1 de 3',
            statSub: 'reclamos',
            text: 'Cuando un cliente reclama un rayón, no tienes evidencia. Y acabas pagando.',
          },
          {
            stat: '15 min',
            statSub: 'de espera',
            text: 'Cuando llueve, esperan 15 minutos por su auto. Y no vuelven.',
          },
        ].map(({ stat, statSub, text }) => (
          <div class="grid lg:grid-cols-[280px_1fr] gap-6 lg:gap-12 py-12 items-start lg:items-center group">
            <div>
              <p
                class="font-serif italic text-[#D85A30] leading-none"
                style="font-size: clamp(2.8rem, 6vw, 4.2rem);"
              >
                {stat}
              </p>
              <p class="font-mono text-[#888780] text-xs tracking-wide mt-1">{statSub}</p>
            </div>
            <p class="text-[#2C2C2A] text-xl md:text-2xl font-medium leading-snug max-w-xl">
              {text}
            </p>
          </div>
        ))}
      </div>

    </div>
  </section>


  <!-- ═══════════════════════════════════════════
       3. CÓMO FUNCIONA — SLIDER
  ═══════════════════════════════════════════ -->
  <section id="como-funciona" class="bg-[#2C2C2A] py-24">
    <div class="max-w-6xl mx-auto px-6">

      <!-- Section marker -->
      <div class="flex items-center gap-3 mb-5">
        <FobIsotipo variant="marker" class="opacity-60" />
        <p class="font-mono text-[#888780] text-[11px] tracking-[.22em] uppercase">Cómo funciona</p>
      </div>

      <h2
        class="font-serif italic text-[#F1EFE8] mb-14"
        style="font-size: clamp(2rem, 4.2vw, 3.2rem); line-height: 1.15;"
      >
        Cinco pasos.<br/>Un servicio impecable.
      </h2>

      <HowItWorks client:load />

    </div>
  </section>


  <!-- ═══════════════════════════════════════════
       4. PARA EL DUEÑO — PANEL ADMIN
  ═══════════════════════════════════════════ -->
  <section id="para-el-dueno" class="bg-[#2C2C2A] py-24">
    <div class="max-w-6xl mx-auto px-6">

      <!-- Section marker -->
      <div class="flex items-center gap-3 mb-5">
        <FobIsotipo variant="marker" class="opacity-60" />
        <p class="font-mono text-[#888780] text-[11px] tracking-[.22em] uppercase">Para el dueño</p>
      </div>

      <div class="grid md:grid-cols-2 gap-16 items-start">

        <!-- Benefits list -->
        <div>
          <h2
            class="font-serif italic text-[#F1EFE8] mb-5"
            style="font-size: clamp(2rem, 4.2vw, 3.2rem); line-height: 1.15;"
          >
            Tú lo ves todo.<br/>En tiempo real.
          </h2>
          <p class="text-[#888780] text-lg leading-relaxed mb-10">
            El panel web de administrador te da visibilidad completa de tu operación, desde cualquier lugar.
          </p>

          <ul class="space-y-6">
            {[
              'Saber cuánto ingresó cada punto cada día.',
              'Ver quién trabajó dónde y cuándo.',
              'Encontrar cualquier vehículo en segundos.',
              'Auditoría completa disponible para casos legales.',
            ].map((item) => (
              <li class="flex items-start gap-4">
                <span class="w-5 h-5 rounded-full border border-[#1D9E75]/50 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <span class="w-1.5 h-1.5 rounded-full bg-[#1D9E75] block"></span>
                </span>
                <span class="text-[#F1EFE8]/80 leading-snug">{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Dashboard mockup -->
        <div class="rounded-xl overflow-hidden border border-white/8 shadow-[0_40px_80px_rgba(0,0,0,.5)]">

          <!-- Browser chrome -->
          <div class="bg-[#1a1a18] px-4 py-2.5 flex items-center gap-3 border-b border-white/5">
            <div class="flex gap-1.5">
              <div class="w-2.5 h-2.5 rounded-full bg-white/15"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-white/15"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-white/15"></div>
            </div>
            <div class="flex-1 bg-white/5 rounded px-3 py-1">
              <span class="font-mono text-[#888780] text-[10px]">admin.proparking.mx/tablero</span>
            </div>
          </div>

          <!-- App shell -->
          <div class="flex bg-[#F8F7F4]" style="min-height: 420px;">

            <!-- Sidebar -->
            <div class="w-44 bg-[#2C2C2A] flex flex-col flex-shrink-0">
              <div class="px-4 py-4 border-b border-white/5">
                <span class="font-mono text-[#F1EFE8] text-xs font-medium tracking-wider">ProParking</span>
              </div>
              <nav class="px-2 py-3 space-y-0.5 flex-1">
                {[
                  { label: 'Tablero', active: true },
                  { label: 'Tickets', active: false },
                  { label: 'Empleados', active: false },
                  { label: 'Reportes', active: false },
                  { label: 'Puntos', active: false },
                ].map(({ label, active }) => (
                  <div class={`px-3 py-2 rounded-lg text-xs font-medium ${active ? 'bg-white/10 text-white' : 'text-[#888780] hover:text-white'}`}>
                    {label}
                  </div>
                ))}
              </nav>
              <div class="px-4 py-3 border-t border-white/5">
                <div class="flex items-center gap-2">
                  <div class="w-1.5 h-1.5 rounded-full bg-[#1D9E75] animate-pulse"></div>
                  <span class="font-mono text-[#888780] text-[9px]">En vivo</span>
                </div>
              </div>
            </div>

            <!-- Main -->
            <div class="flex-1 flex flex-col overflow-hidden">

              <!-- Header -->
              <div class="px-5 py-3.5 border-b border-[#2C2C2A]/8 flex items-center justify-between bg-white">
                <div>
                  <p class="font-semibold text-[#2C2C2A] text-sm">Tablero general</p>
                  <p class="font-mono text-[#888780] text-[10px]">Martes 10 jun 2026</p>
                </div>
                <div class="flex items-center gap-1.5">
                  <div class="w-1.5 h-1.5 rounded-full bg-[#1D9E75]"></div>
                  <span class="font-mono text-[#1D9E75] text-[10px]">en vivo</span>
                </div>
              </div>

              <!-- KPI cards -->
              <div class="grid grid-cols-4 gap-2 px-4 py-3">
                {[
                  { label: 'Ingresos hoy',     value: '$8,400', sub: '+12% vs ayer',  coral: true },
                  { label: 'Vehículos',         value: '47',     sub: '8 en patio'                 },
                  { label: 'Empleados',         value: '5',      sub: 'activos ahora'               },
                  { label: 'Tickets abiertos',  value: '12',     sub: '3 en espera'                 },
                ].map(({ label, value, sub, coral }) => (
